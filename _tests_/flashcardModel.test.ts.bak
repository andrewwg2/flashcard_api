
import mongoose from 'mongoose';
import Flashcard from '../src/models/flashcardModel';
import dotenv from 'dotenv';

const base = '/api/flashcards';


dotenv.config();
describe('Flashcard Model', () => {
  beforeAll(async () => {
    try {
      await mongoose.connect(process.env.MONGO_URI!);
      console.log('Database connected successfully');
    } catch (error) {
      console.error('Database connection failed:', error);
    }
  });

  afterAll(async () => {
    await mongoose.disconnect();
  });

  beforeEach(async () => {
    await Flashcard.deleteMany({});
  });

  it('should update stats correctly', async () => {
    const flashcard = new Flashcard({
      spanishWord: 'Hola',
      englishWord: 'Hello',
      category: 'Greetings',
    });

    await flashcard.save();

    
    flashcard.updateStats(true);
    await flashcard.save();

    expect(flashcard.timesSeen).toBe(1);
    expect(flashcard.percentageCorrect).toBe(1);

    flashcard.updateStats(false);
    await flashcard.save();

    expect(flashcard.timesSeen).toBe(2);
    expect(flashcard.percentageCorrect).toBe(0.5);
  });
});
